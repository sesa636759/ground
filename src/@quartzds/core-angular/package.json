{
  "name": "@quartzds/core-angular",
  "version": "1.0.0-beta.91",
  "description": "Angular wrapper for @quartzds/core",
  "homepage": "https://github.com/quartzds/core-foundations/tree/main/packages/angular",
  "bugs": {
    "url": "https://github.com/quartzds/core-foundations/issues"
  },
  "repository": "https://github.com/quartzds/core-foundations",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json",
    "./styles/*": "./styles/*"
  },
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "lib/**",
    "styles/**"
  ],
  "scripts": {
    "build": "ngc",
    "clean": "rimraf .turbo/ lib/ node_modules/ styles/",
    "dev": "ngc -w"
  },
  "dependencies": {
    "@quartzds/core": "1.0.0-beta.90",
    "tslib": "^2.0.0"
  },
  "devDependencies": {
    "@angular/common": "18.2.8",
    "@angular/compiler": "18.2.8",
    "@angular/compiler-cli": "18.2.8",
    "@angular/core": "18.2.8",
    "@angular/forms": "18.2.8",
    "@angular/platform-browser": "18.2.8",
    "rimraf": "5.0.10",
    "rxjs": "7.8.1",
    "typescript": "5.5.4",
    "zone.js": "0.14.10"
  },
  "peerDependencies": {
    "@angular/common": ">=16.1.0",
    "@angular/core": ">=16.1.0",
    "@angular/forms": ">=16.1.0",
    "@angular/platform-browser": ">=16.1.0",
    "rxjs": ">= 6.5.3",
    "zone.js": ">= 0.13.0"
  },
  "engines": {
    "node": ">=18.12.0"
  }
}
